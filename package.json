{
  "name": "form-auto-mcp",
  "version": "1.0.2",
  "description": "MCP server for Claude Desktop that automates form submissions using Playwright",
  "main": "dist/index.js",
  "bin": {
    "form-auto-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "npx playwright install chromium"
  },
  "keywords": ["mcp", "playwright", "form-automation", "claude-desktop"],
  "author": "jayounglee92",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jayounglee92/form-auto-mcp.git"
  },
  "homepage": "https://github.com/jayounglee92/form-auto-mcp",
  "type": "commonjs",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "googleapis": "^171.4.0",
    "playwright": "^1.58.2",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
